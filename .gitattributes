# Auto-manage line endings for cross-platform compatibility.
# Git stores LF internally; checkout uses native line endings per OS.
* text=auto

# Python files: always LF on checkout (cross-platform consistency)
*.py text eol=lf

# Shell scripts: always LF on checkout
*.sh text eol=lf

# Markdown: native line endings per platform
*.md text

# Binary files: never convert
*.png binary
*.jpg binary
*.zip binary
*.gguf binary
